<div class="col">
  <a href="{% if topic.redirect %}{{ topic.redirect }}{% else %}{{ topic.url | relative_url }}{% endif %}">
    <div class="card h-100 hoverable">
      {% if topic.img %}
        {%
          include figure.liquid
          loading="eager"
          path=topic.img
          sizes = "250px"
          alt="topic thumbnail"
          class="card-img-top"
        %}
      {% endif %}
      <div class="card-body">
        <h2 class="card-title">{{ topic.title }}</h2>
        <p class="card-text">{{ topic.description }}</p>
        {% include topic_tags.liquid topic=topic %}
        <div class="row ml-1 mr-1 p-0">
          {% if topic.github %}
            <div class="github-icon">
              <div class="icon" data-toggle="tooltip" title="Code Repository">
                <a href="{{ topic.github }}"><i class="fa-brands fa-github gh-icon"></i></a>
              </div>
              {% if topic.github_stars %}
                <span class="stars" data-toggle="tooltip" title="GitHub Stars">
                  <i class="fa-solid fa-star"></i>
                  <span id="{{ topic.github_stars }}-stars"></span>
                </span>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </a>
</div>
